{
  "name": "animal-island-ui-solid",
  "version": "0.9.5",
  "description": "A nature-inspired SolidJS component library",
  "keywords": [
    "animal-island-ui-solid",
    "component-library",
    "nature",
    "solidjs",
    "theme",
    "typescript",
    "ui"
  ],
  "homepage": "https://zuisong.github.io/animal-island-ui-solid/",
  "bugs": {
    "url": "https://github.com/zuisong/animal-island-ui-solid/issues"
  },
  "license": "MIT",
  "author": "zuisong",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuisong/animal-island-ui-solid"
  },
  "files": [
    "dist",
    "AI_USAGE.md",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "main": "dist/es/index.js",
  "module": "dist/es/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js"
    },
    "./style": "./dist/index.css",
    "./dist/index.css": "./dist/index.css"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "build:demo": "vite build --config vite.config.demo.ts",
    "dev:demo": "vite dev --config vite.config.demo.ts",
    "prepublishOnly": "npm run build",
    "deploy": "npm run build:demo && gh-pages -d demo-dist"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/nunito": "^5.2.7",
    "classnames": "^2.5.1",
    "modern-screenshot": "^4.6.0",
    "solid-js": "2.0.0-beta.14",
    "@solidjs/web": "2.0.0-beta.14"
  },
  "devDependencies": {
    "@laynezh/vite-plugin-lib-assets": "^2.1.3",
    "@types/node": "^25.5.2",
    "gh-pages": "^6.3.0",
    "less": "^4.6.4",
    "typescript": "^5.7.3",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "3.0.0-next.5"
  },
  "peerDependencies": {
    "solid-js": ">=2.0.0-beta.0"
  }
}
