{
    "name": "animal-island-ui",
    "version": "1.0.16",
    "description": "A nature-inspired React component library",
    "type": "module",
    "main": "dist/cjs/index.cjs",
    "module": "dist/es/index.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/es/index.js",
            "require": "./dist/cjs/index.cjs"
        },
        "./style": "./dist/index.css",
        "./dist/index.css": "./dist/index.css",
        "./es/*": "./dist/es/*",
        "./items/*": "./dist/items/*"
    },
    "files": [
        "dist",
        "items.d.ts",
        "AI_USAGE.md",
        "README.md"
    ],
    "sideEffects": false,
    "repository": {
        "type": "git",
        "url": "https://github.com/guokaigdg/animal-island-ui"
    },
    "homepage": "https://github.com/guokaigdg/animal-island-ui#readme",
    "bugs": {
        "url": "https://github.com/guokaigdg/animal-island-ui/issues"
    },
    "author": "guokaigdg",
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
        "build:demo": "vite build --config vite.config.demo.ts",
        "prepublishOnly": "npm run build",
        "deploy": "npm run build:demo && gh-pages -d demo-dist",
        "test": "vitest",
        "test:run": "vitest run",
        "test:cov": "vitest run --coverage --reporter=json --outputFile=coverage/vitest-results.json",
        "badges": "node scripts/generate-coverage-badges.mjs",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "ci": "npm run format:check && npm run lint && npm run test:run && npm run build"
    },
    "peerDependencies": {
        "react": ">=17.0.0",
        "react-dom": ">=17.0.0",
        "classnames": "^2.5.1"
    },
    "dependencies": {
        "@fontsource/noto-sans-sc": "^5.2.9",
        "@fontsource/nunito": "^5.2.7",
        "modern-screenshot": "^4.6.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@laynezh/vite-plugin-lib-assets": "^2.1.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.5.2",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^5.2.0",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^9.0.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-react-refresh": "^0.4.12",
        "gh-pages": "^6.3.0",
        "globals": "^15.0.0",
        "jsdom": "^29.1.1",
        "less": "^4.2.1",
        "prettier": "^3.4.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.0.0",
        "vite": "^7.3.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.8"
    },
    "keywords": [
        "react",
        "component-library",
        "ui",
        "typescript",
        "theme",
        "animal-island-ui",
        "nature"
    ],
    "license": "MIT"
}
