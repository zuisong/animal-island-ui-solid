{
    "name": "animal-island-ui-solid",
    "version": "0.9.5",
    "description": "A nature-inspired SolidJS component library",
    "type": "module",
    "main": "dist/cjs/index.cjs",
    "module": "dist/es/index.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/es/index.js",
            "require": "./dist/cjs/index.cjs"
        },
        "./style": "./dist/index.css",
        "./dist/index.css": "./dist/index.css"
    },
    "files": [
        "dist",
        "AI_USAGE.md",
        "README.md"
    ],
    "sideEffects": [
        "**/*.css",
        "**/*.less"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/guokaigdg/animal-island-ui-solid"
    },
    "homepage": "https://github.com/guokaigdg/animal-island-ui-solid#readme",
    "bugs": {
        "url": "https://github.com/guokaigdg/animal-island-ui-solid/issues"
    },
    "author": "guokaigdg",
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
        "build:demo": "vite build --config vite.config.demo.ts",
        "dev:demo": "vite dev --config vite.config.demo.ts",
        "prepublishOnly": "npm run build",
        "deploy": "npm run build:demo && gh-pages -d demo-dist"
    },
    "peerDependencies": {
        "solid-js": "^1.9.0"
    },
    "dependencies": {
        "@fontsource/noto-sans-sc": "^5.2.9",
        "@fontsource/nunito": "^5.2.7",
        "classnames": "^2.5.1",
        "modern-screenshot": "^4.6.0",
        "solid-js": "^1.9.5"
    },
    "devDependencies": {
        "@laynezh/vite-plugin-lib-assets": "^2.1.3",
        "@types/node": "^25.5.2",
        "gh-pages": "^6.3.0",
        "less": "^4.2.1",
        "typescript": "^5.7.3",
        "vite": "^7.3.2",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-solid": "^2.11.6"
    },
    "keywords": [
        "solidjs",
        "component-library",
        "ui",
        "typescript",
        "theme",
        "animal-island-ui-solid",
        "nature"
    ],
    "license": "MIT"
}
