#!/usr/bin/env sh
#  在 commit 之前自动跑 `npm run ci`
#  失败 → commit 中止 (必须先修问题)
#  紧急绕过 (不推荐) : git commit --no-verify
#  卸载             : git config --unset core.hooksPath
#  重装             : npm run setup:hooks

set -e

echo "                                                                                      "
echo "                                                                                      "
echo "  ▄▄▄  ▄▄  ▄▄ ▄▄ ▄▄   ▄▄  ▄▄▄  ▄▄      ▄▄  ▄▄▄▄ ▄▄     ▄▄▄  ▄▄  ▄▄ ▄▄▄▄      ▄▄ ▄▄ ▄▄ "
echo " ██▀██ ███▄██ ██ ██▀▄▀██ ██▀██ ██  ▄▄▄ ██ ███▄▄ ██    ██▀██ ███▄██ ██▀██ ▄▄▄ ██ ██ ██ "
echo " ██▀██ ██ ▀██ ██ ██   ██ ██▀██ ██▄▄▄   ██ ▄▄██▀ ██▄▄▄ ██▀██ ██ ▀██ ████▀     ▀███▀ ██"
echo ""
echo "          ╔══════════════════════════════════════════════════════════════╗"
echo "          ║  pre-commit: running CI (format/check:docs/lint/test/build)  ║"
echo "          ╚══════════════════════════════════════════════════════════════╝"
echo ""

if npm run ci; then
    echo ""
    echo "✅ CI 通过,继续 commit"
    echo ""
    exit 0
else
    CI_EXIT=$?
    echo ""
    echo "❌ CI 失败(exit: $CI_EXIT),commit 已中止"
    echo "   修复上面的错误后再 commit。"
    echo "   紧急绕过(不推荐):git commit --no-verify"
    echo ""
    exit 1
fi
